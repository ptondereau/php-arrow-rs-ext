{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "ptondereau/parquet-php",
    "description": "PHP extension for reading and writing Apache Parquet files, powered by arrow-rs",
    "license": "MIT",
    "type": "php-ext",
    "authors": [
        {
            "name": "Pierre Tondereau",
            "email": "pierre.tondereau@protonmail.com"
        }
    ],
    "autoload": {
        "classmap": [
            "parquet.stubs.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Parquet\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "carthage-software/mago": "^1",
        "flow-php/parquet": "^0.32 || ^0.33"
    },
    "config": {
        "allow-plugins": {
            "carthage-software/mago": true
        }
    },
    "php-ext": {
        "build-path": "pie",
        "extension-name": "parquet",
        "support-zts": true,
        "support-nts": true,
        "download-url-method": "composer-default",
        "configure-options": [
            {
                "name": "debug",
                "description": "Build in debug mode",
                "needs-value": false
            }
        ]
    }
}
